config {
    id "urn:com.arcadiaeditions:fulfillment:shipping"
    title "Arcadia Editions - Fulfillment Shipping"
    basePackage "com.arcadiaeditions.fulfillment.shipping"
    persistence jpa

    plugins {
        /** Generates an AsyncAPI v3 specification from this ZDL model. */
        ZDLToAsyncAPIPlugin {
            id "urn:com.arcadiaeditions:fulfillment:shipping:asyncapi"
            schemaFormat avro
            idType integer
            idTypeFormat int64
            avroPackage com.arcadiaeditions.fulfillment.shipping.events.avro
            includeCloudEventsHeaders true
            includeKafkaCommonHeaders true
            targetFile "./asyncapi.yml"
        }
        ZDLToAsyncAPIClientPlugin {
            id "urn:com.arcadiaeditions:fulfillment:shipping:asyncapi:client"
            title "Arcadia Editions - Fulfillment Shipping - AsyncAPI Client"
            targetFile "./asyncapi-client.yml"
        }
        /** Generates an OpenAPI 3.0 specification from this ZDL model. */
        ZDLToOpenAPIPlugin {
            idType integer
            idTypeFormat int64
            targetFile "./openapi.yml"
        }
    }
}

apis {
    asyncapi client OrdersCheckoutApi "https://raw.githubusercontent.com/arcadia-editions/orders-checkout-api/main/asyncapi.yml"
}

@aggregate
@lifecycle(field: status, initial: SCHEDULED)
entity Fulfillment {
    fulfillmentId String required unique
    orderId String required unique
    customerId String required
    status FulfillmentStatus required
    carrierCode String
    trackingNumber String
    scheduledAt Instant
    readyAt Instant
    failedAt Instant
    failureReason String
}

enum FulfillmentStatus {
    SCHEDULED
    READY_TO_SHIP
    FAILED
}

input ScheduleFulfillmentInput {
    orderId String required
    customerId String required
    shippingAddress ShippingAddressInput required
    items FulfillmentItemInput[] required
}

input ShippingAddressInput {
    name String required
    line1 String required
    line2 String
    city String required
    region String
    postalCode String required
    country String required
}

input FulfillmentItemInput {
    sku String required
    quantity Integer required
}

@rest("/fulfillments")
service FulfillmentShippingService for (Fulfillment) {

    @asyncapi(api: OrdersCheckoutApi, channel: "order-confirmed-event-v1")
    @transition(to: SCHEDULED)
    scheduleFulfillment(ScheduleFulfillmentInput) Fulfillment withEvents [FulfillmentScheduled | FulfillmentFailed]

    @transition(from: SCHEDULED, to: READY_TO_SHIP)
    markReadyToShip(id) Fulfillment withEvents FulfillmentReadyToShip
}

@asyncapi({ channel: "fulfillment-scheduled-event-v1", topic: "fulfillment-shipping.fulfillment-scheduled.event.avro.v1" })
event FulfillmentScheduled {
    fulfillmentId String
    orderId String
    customerId String
    scheduledAt Instant
}

@asyncapi({ channel: "fulfillment-failed-event-v1", topic: "fulfillment-shipping.fulfillment-failed.event.avro.v1" })
event FulfillmentFailed {
    fulfillmentId String
    orderId String
    customerId String
    reason String
    failedAt Instant
}

@asyncapi({ channel: "fulfillment-ready-to-ship-event-v1", topic: "fulfillment-shipping.fulfillment-ready-to-ship.event.avro.v1" })
event FulfillmentReadyToShip {
    fulfillmentId String
    orderId String
    customerId String
    carrierCode String
    trackingNumber String
    readyAt Instant
}
